# Variables d'environnement — copier en `.env` (non versionné) pour l'exécution.
# En dev, on préfère les passer en ligne (ex. `npm run dev:auth`) : le code ne charge PAS de .env.
# Sur le NAS, `deploy/docker-compose.nas.yml` lit ce fichier placé à côté de lui.

# --- Authentification & rôles (exposition externe) ---
# viewer = consultation. Vide (avec ADMIN_PASSWORD vide) → authentification désactivée.
APP_USER=marees
APP_PASSWORD=

# admin = édition des réglages + statistiques, depuis n'importe où.
ADMIN_USER=admin
ADMIN_PASSWORD=

# Force le flag Secure du cookie de session même si le proxy ne transmet pas X-Forwarded-Proto.
COOKIE_SECURE=true

# Secret de signature du jeton de session. Optionnel : par défaut dérivé de APP_PASSWORD
# (changer le mot de passe révoque alors les sessions). Le définir permet de révoquer sans
# changer le mot de passe.
SESSION_SECRET=

# --- Runtime ---
# Répertoire de données (settings.json + horaires + journal d'accès). Défaut : <cwd>/data.
DATA_DIR=/data
# Port d'écoute (défaut 3000).
PORT=3000
# Niveau de log pino (trace|debug|info|warn|error). Défaut info.
LOG_LEVEL=info
